# App
APP_ENV=local
PORT=3333

# Database
DATABASE_URL=postgresql://postgres:password@db:5432/db?schema=public

# Auth
JWT_SECRET=your-secret-key-change-in-test
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=auth_token
AUTH_COOKIE_MAX_AGE=604800

# CORS
CORS_ALLOW_ORIGINS=http://localhost:3333

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
