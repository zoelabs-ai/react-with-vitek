{
  "name": "react-with-vitek",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "./scripts/run-dev.sh",
    "simulate:prod": "./scripts/simulate-prod.sh",
    "start": "vitek-serve",
    "prebuild": "prisma generate",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:staged": "lint-staged",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky"
  },
  "dependencies": {
    "@chakra-ui/react": "^3",
    "@emotion/react": "^11",
    "@prisma/adapter-pg": "^7",
    "@prisma/client": "^7.4.2",
    "axios": "^1",
    "bcryptjs": "^3",
    "dotenv": "^16",
    "jotai": "^2",
    "jsonwebtoken": "^9",
    "pg": "^8",
    "prisma": "^7",
    "react": "^19",
    "react-dom": "^19",
    "react-router-dom": "^7",
    "@tanstack/react-query": "^5",
    "vitek-plugin": "0.2.2-beta"
  },
  "devDependencies": {
    "@commitlint/cli": "^19",
    "@commitlint/config-conventional": "^19",
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2",
    "@types/jsonwebtoken": "^9",
    "@types/node": "^22",
    "@types/pg": "^8",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^15",
    "husky": "^9",
    "lint-staged": "^15",
    "pretty-quick": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vite": "^6",
    "vitepress": "2.0.0-alpha.17",
    "vitest": "^4"
  }
}